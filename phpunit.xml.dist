<?xml version="1.0" encoding="UTF-8"?>
<phpunit colors="true" cacheDirectory=".phpunit.cache">
	<testsuites>
		<testsuite name="Theme">
			<directory>tests</directory>
		</testsuite>
	</testsuites>
	<coverage>
		<include>
			<directory suffix=".php">inc</directory>
		</include>
	</coverage>
</phpunit>

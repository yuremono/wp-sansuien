:root {
  --trt:translate 1s,opacity 1s .2s,clip-path 1s .2s;
  --bw:20px;
}

.js-left, .js-right, .js-top, .js-bottom, .js-chB :is(.box, li) {
  transition: var(--trt);
  opacity: 0;
}
.js-left.show, .js-right.show, .js-top.show, .js-bottom.show, .js-chB :is(.box, li).show {
  translate: none;
  opacity: 1;
}
.js-hide {
  filter: blur(var(--bw));
  opacity: 0;
  translate: 0 var(--bw);
  transition: 0.8s;
}
.js-hide.show {
  opacity: 1;
  visibility: visible;
  --bw:0px;
}
.js-right {
  translate: 8vmin;
}
.js-left {
  translate: -8vmin;
}
.js-bottom, .js-chB :is(.box, li) {
  translate: 0 4vh;
}
.js-top {
  translate: 0 -4vmin;
}

[class*=js-clip] {
  --trt2:all .4s ;
  transition: var(--trt2);
  -webkit-clip-path: polygon(0% 0%, 0% 0%, 0% 100%, 0% 100%);
          clip-path: polygon(0% 0%, 0% 0%, 0% 100%, 0% 100%);
}
[class*=js-clip]:after {
  background-color: var(--bgc);
  transform-origin: right;
  transition: var(--trt2);
  transition-delay: 0.4s;
}
[class*=js-clip].js-clipR {
  -webkit-clip-path: polygon(100% 0%, 100% 0%, 100% 100%, 100% 100%);
          clip-path: polygon(100% 0%, 100% 0%, 100% 100%, 100% 100%);
}
[class*=js-clip].js-clipR:after {
  transform-origin: left;
}
[class*=js-clip] img:is(#contents img):not(.boxgrow img) {
  float: none;
  width: 100%;
}
[class*=js-clip].show {
  -webkit-clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%);
          clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%);
}
[class*=js-clip].show:after {
  scale: 0 1;
}


  content: "A";
  color: var(--ff);
  background-color: var(--mc);
  display: block;
  position: absolute;
  left: 0.3em;
  top: 50%;
  translate: 0 -50%;
  font-size: var(--f24);
  font-weight: bold;
  width: 1.5em;
  aspect-ratio: 1;
  display: grid;
  place-items: center;
}
.dl_qa dl:is(#contents dl) dd.show {

  --strokewh:drop-shadow(0 0 var(--stW) var(--stC))drop-shadow(0 0 var(--stW) var(--stC))drop-shadow(0 0 var(--stW) var(--stC))drop-shadow(0 0 var(--stW) var(--stC))drop-shadow(0 0 var(--stW) var(--stC))drop-shadow(0 0 var(--stW) var(--stC))drop-shadow(0 0 var(--stW) var(--stC))drop-shadow(0 0 var(--stW) var(--stC));
  --txsh-mc:0 0 var(--stW) var(--mc),0 0 var(--stW) var(--mc),0 0 var(--stW) var(--mc),0 0 var(--stW) var(--mc),0 0 var(--stW) var(--mc),0 0 var(--stW) var(--mc);
  --stroke-ac:0 0 var(--stW) var(--ac),0 0 var(--stW) var(--ac),0 0 var(--stW) var(--ac),0 0 var(--stW) var(--ac),0 0 var(--stW) var(--ac),0 0 var(--stW) var(--ac);

:root {
  --w:10vmin;
  --incont:calc(50vw - clamp(0px,calc(50vw - var(--pad,20px)),calc((var(--base) / 2) + var(--bar,0px) / 2)));
  --in1728:calc(50vw - clamp(0px,calc(50vw - var(--pad,20px)),calc(864px + var(--bar,0px) / 2)));

.btn.LB, .LB.btn-g, .LB.btn-ac, .LB.btn-s-bk, .LB.btn-s, .LB.btn-lg, .LB.btn-wh, .LB.btn2 {
  float: left;
  margin-top: auto;
  margin-right: auto;
}

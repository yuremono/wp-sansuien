  background-image: repeating-linear-gradient(90deg, #fff, #fff 1.4px, transparent 1.6px, transparent 16px), repeating-linear-gradient(0deg, #fff, #fff 1.4px, #edeff1 1.6px, #edeff1 16px);
}


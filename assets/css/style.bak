.card_slide, .blog_slide4 {
  position: relative;
  /* 追加 */
}
.card_slide img, .blog_slide4 img {
  aspect-ratio: 4/3;
  -o-object-fit: cover;
     object-fit: cover;
}
.card_slide article div, .blog_slide4 article div {
  padding: 1em;
  background-color: #fff;
}
.card_slide #arrows, .blog_slide4 #arrows {
  padding-block: var(--block);
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20px;
  padding-right: var(--in1200);
}
.card_slide .slick-list, .blog_slide4 .slick-list {
  overflow: visible;
}
.card_slide .slick-next, .card_slide .slick-prev, .blog_slide4 .slick-next, .blog_slide4 .slick-prev {
  width: unset;
  height: unset;
  transform: unset;
  margin: 0;
  z-index: 100;
  top: -65px;
  position: static;
}
.card_slide .slick-prev, .blog_slide4 .slick-prev {
  left: unset;
  right: 95px;
  scale: -1 1;
}
.card_slide .slick-next, .blog_slide4 .slick-next {
  right: 15px;
}
.card_slide .slick-prev:before, .card_slide .slick-next:before, .blog_slide4 .slick-prev:before, .blog_slide4 .slick-next:before {
  font-family: var(--fa);
  content: "\f054";
  font-size: 20px;
  width: 50px;
  height: 50px;
  background-color: var(--ff);
  display: grid;
  place-items: center;
  border-radius: 1000px;
  font-weight: 900;
  color: #4A5568;
  border: 1px solid var(--gr);
}
.card_slide .slick-slide, .blog_slide4 .slick-slide {
  padding-inline: 2vmin;
}
.card_slide .slick-slide a, .blog_slide4 .slick-slide a {
  position: relative;
  box-shadow: var(--bs);
}
.card_slide .slick-slide a:after, .blog_slide4 .slick-slide a:after {
  width: 2em;
  height: 2em;
  background: url(../images/home/arrow07.png) no-repeat center/var(--f18);
  background-color: #fff;
  transform-origin: right bottom;
  transition: 0.4s;
}
.card_slide .slick-slide a div, .blog_slide4 .slick-slide a div {
  font-weight: 700;
  text-shadow: var(--stroke);
}
.card_slide .slick-slide a:hover:after, .blog_slide4 .slick-slide a:hover:after {
  scale: 1.2;
}
.card_slide .slider-dots, .blog_slide4 .slider-dots {
  width: 200px;
  margin: 0;
  padding: 0;
  text-align: center;
  display: flex;
  align-items: center;
  height: 0;
}
.card_slide .slider-dots li, .blog_slide4 .slider-dots li {
  display: inline-block;
  width: calc(100% / var(--li)); /* プログレスバーの横幅はスライドの枚数に合わせて調整してください */
  height: 0px;
}
.card_slide .slider-dots button, .blog_slide4 .slider-dots button {
  position: relative;
  width: 100%;
  height: 4px;
  border: 0;
  background-color: #ccc;
  font-size: 0;
  display: block;
}
.card_slide .slider-dots button:after, .blog_slide4 .slider-dots button:after {
  position: absolute;
  top: 0;
  left: 0;
  content: "";
  display: block;
  width: 0%;
  height: 100%;
}
.card_slide .slick-active button:after, .blog_slide4 .slick-active button:after {
  background-color: #000;
  width: 100%;
}
@keyframes progress {
  from {
    width: 0%;
  }
  to {
    width: 100%;
  }
}


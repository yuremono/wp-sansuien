.btn.__invert:hover, .__invert.btn-g:hover, .__invert.btn-ac:hover, .__invert.btn-s-bk:hover, .__invert.btn-s:hover, .__invert.btn-lg:hover, .__invert.btn-wh:hover, .__invert.btn2:hover {
  filter: unset;

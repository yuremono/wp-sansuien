# Copy this file to .env.deploy (gitignored) and fill in the real values below.
DEPLOY_HOST=your-server.example.com
DEPLOY_USER=your-ssh-user
DEPLOY_PORT=22
DEPLOY_THEME_SLUG=sansuien
DEPLOY_ZIP_NAME=sansuien-theme.zip

DEPLOY_PATH=/absolute/path/to/wp-content/themes/sansuien
DEPLOY_WP_PATH=/absolute/path/to/wordpress-root

# Optional. Set only if XML import is explicitly required.
# DEPLOY_IMPORT_XML=/absolute/path/to/sansuien-wp-content.xml
